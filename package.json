{
    "name": "intento-app",
    "version": "1.0.1",
    "description": "Intento - AI-powered cursor assistant for intelligent text responses",

    "author": "Intento Team",
    "main": "src/main/index.js",
    "scripts": {
        "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
        "build": "vite build && electron-builder",
        "release": "vite build && electron-builder --publish always",
        "vite:dev": "vite",

        "electron:dev": "electron .",
        "python:install": "cd python && pip install -r requirements.txt",
        "python:dev": "cd python && python main.py"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@google/generative-ai": "^0.21.0",
        "@jitsi/robotjs": "^0.6.13",
        "axios": "^1.6.0",
        "clipboardy": "2.3.0",
        "dotenv": "^16.4.0",
        "electron-store": "^8.1.0",
        "electron-updater": "^6.8.3",
        "lucide-react": "^0.344.0",
        "ollama": "^0.5.8",
        "openai": "^6.18.0",
        "pdf-parse": "^1.1.1",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "zustand": "^4.5.0"
    },
    "devDependencies": {
        "@vitejs/plugin-react": "^4.2.1",
        "concurrently": "^8.2.2",
        "electron": "^33.0.0",
        "electron-builder": "^24.9.1",
        "png-to-ico": "^3.0.1",
        "sass": "^1.70.0",
        "vite": "^5.0.12",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.intento.app",
        "productName": "Intento",
        "directories": {
            "output": "release"
        },
        "asarUnpack": [
            "**/node_modules/@jitsi/robotjs/**/*"
        ],
        "publish": [

            {
                "provider": "github",
                "owner": "shnwz3",
                "repo": "intento"
            }
        ],

        "files": [
            "src/main/**/*",
            "src/preload/**/*",
            "src/shared/**/*",
            "dist/**/*",
            "ai_config.json"
        ],
        "win": {
            "target": [
                "nsis"
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
